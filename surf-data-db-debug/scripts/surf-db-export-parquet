#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# dependencies = ["duckdb"]
# ///
"""
Export database query results to Parquet via DuckDB.

Usage:
    uv run surf-db-export-parquet --env stg --sql "SELECT ..." --output /tmp/data.parquet
    uv run surf-db-export-parquet --host localhost --port 15432 --user ro --password x --dbname mydb --sql "SELECT ..."
    uv run surf-db-export-parquet --check-setup

Config: ~/.config/surf-db/config.json (same as surf-db-query).
"""

import argparse
import hashlib
import json
import os
import socket
import sys
from datetime import datetime
from pathlib import Path

CONFIG_FILE = Path.home() / ".config" / "surf-db" / "config.json"
DEFAULT_OUTPUT_DIR = Path("/tmp/surf-export")

RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
NC = "\033[0m"


def log_info(msg):
    print(f"{GREEN}✓{NC} {msg}")


def log_warn(msg):
    print(f"{YELLOW}⚠{NC} {msg}")


def log_error(msg):
    print(f"{RED}✗{NC} {msg}", file=sys.stderr)


def load_config():
    if not CONFIG_FILE.exists():
        log_error(f"Config file not found: {CONFIG_FILE}")
        print("    Set up surf-data-db-debug first: ~/.claude/skills/surf-data-db-debug/references/setup.md")
        sys.exit(1)
    with open(CONFIG_FILE) as f:
        return json.load(f)


def parse_env_arg(env_str):
    if ":" in env_str:
        env, db = env_str.split(":", 1)
        return env, db
    return env_str, None


def get_default_db(env, config):
    env_config = config.get("environments", {}).get(env, {})
    default_db = env_config.get("default_db")
    if default_db:
        return default_db
    dbs = env_config.get("databases", {})
    if dbs:
        return next(iter(dbs))
    return None


def get_tunnel_port(env, db_name, config):
    custom_port = (
        config.get("environments", {})
        .get(env, {})
        .get("databases", {})
        .get(db_name, {})
        .get("tunnel_port")
    )
    if custom_port:
        return int(custom_port)
    # Same hash algorithm as surf-db-query
    hash_hex = hashlib.md5(f"{env}-{db_name}".encode()).hexdigest()[:4]
    offset = int(hash_hex, 16) % 1000
    return 15432 + offset


def get_db_params(env, db_name, config):
    db_config = config["environments"][env]["databases"][db_name]
    password = db_config.get("password", "")
    password_cmd = db_config.get("password_cmd")
    if password_cmd:
        import subprocess

        password = subprocess.check_output(password_cmd, shell=True).decode().strip()
    return {
        "host": "localhost",
        "port": get_tunnel_port(env, db_name, config),
        "user": db_config["user"],
        "password": password,
        "dbname": db_config["name"],
        "db_type": db_config.get("type", "postgres"),
    }


def check_port_listening(port):
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        return s.connect_ex(("localhost", port)) == 0


def is_write_operation(sql):
    stripped = sql.strip().upper()
    write_prefixes = (
        "INSERT",
        "UPDATE",
        "DELETE",
        "DROP",
        "CREATE",
        "ALTER",
        "TRUNCATE",
        "GRANT",
        "REVOKE",
        "REPLACE",
        "MERGE",
    )
    return stripped.startswith(write_prefixes)


def export_to_parquet(sql, output_path, host, port, user, password, dbname, db_type):
    import duckdb

    conn = duckdb.connect()

    # Escape single quotes in password for the connection string
    safe_password = password.replace("'", "\\'")

    if db_type in ("postgres", "postgresql"):
        conn.execute("INSTALL postgres; LOAD postgres;")
        dsn = f"dbname={dbname} host={host} port={port} user={user} password={safe_password}"
        conn.execute(f"ATTACH '{dsn}' AS src (TYPE POSTGRES, READ_ONLY);")
    elif db_type == "mysql":
        conn.execute("INSTALL mysql; LOAD mysql;")
        conn.execute(
            f"ATTACH 'host={host} port={port} user={user} password={safe_password} database={dbname}' "
            f"AS src (TYPE MYSQL, READ_ONLY);"
        )
    else:
        log_error(f"Unsupported database type: {db_type}")
        sys.exit(1)

    conn.execute("USE src;")
    conn.execute(f"COPY ({sql}) TO '{output_path}' (FORMAT PARQUET);")
    conn.close()


def check_setup():
    print("Checking surf-db-export-parquet setup...")
    print()
    errors = 0

    # Check uv
    if os.system("command -v uv > /dev/null 2>&1") == 0:
        log_info("uv available")
    else:
        log_error("uv not found — install from https://docs.astral.sh/uv/")
        errors += 1

    # Check DuckDB importable
    try:
        import duckdb

        log_info(f"DuckDB available (version {duckdb.__version__})")
    except ImportError:
        log_warn("DuckDB not yet installed (will be auto-installed by uv run)")

    # Check config
    if CONFIG_FILE.exists():
        log_info(f"Config file exists: {CONFIG_FILE}")
        config = load_config()
        for env_name in config.get("environments", {}):
            log_info(f"  Environment '{env_name}' configured")
    else:
        log_error(f"Config file not found: {CONFIG_FILE}")
        print("    Set up surf-data-db-debug first: ~/.claude/skills/surf-data-db-debug/references/setup.md")
        errors += 1

    print()
    if errors == 0:
        log_info("Setup complete!")
    else:
        log_error("Setup incomplete. Please fix the errors above.")
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(
        description="Export database query results to Parquet via DuckDB."
    )
    parser.add_argument("--env", help="Environment (stg, prd) or env:db (stg:main)")
    parser.add_argument("--sql", help="SQL query to execute and export")
    parser.add_argument("--output", help="Output parquet file path")
    parser.add_argument("--host", default="localhost", help="Direct mode: database host")
    parser.add_argument("--port", type=int, help="Direct mode: database port")
    parser.add_argument("--user", help="Direct mode: database user")
    parser.add_argument("--password", help="Direct mode: database password")
    parser.add_argument("--dbname", help="Direct mode: database name")
    parser.add_argument(
        "--db-type", default="postgres", help="Direct mode: postgres or mysql"
    )
    parser.add_argument(
        "--check-setup", action="store_true", help="Verify dependencies"
    )

    args = parser.parse_args()

    if args.check_setup:
        check_setup()
        return

    if not args.sql:
        parser.error("--sql is required")

    if is_write_operation(args.sql):
        log_error("Write operations are not supported for parquet export")
        sys.exit(1)

    # Resolve connection params
    if args.env:
        config = load_config()
        env, db = parse_env_arg(args.env)

        if env not in config.get("environments", {}):
            log_error(f"Environment '{env}' not found in config")
            sys.exit(1)

        db_name = db or get_default_db(env, config)
        if not db_name:
            log_error(f"No database found for environment '{env}'")
            sys.exit(1)

        if db_name not in config["environments"][env].get("databases", {}):
            log_error(f"Database '{db_name}' not found in environment '{env}'")
            sys.exit(1)

        params = get_db_params(env, db_name, config)

        if not check_port_listening(params["port"]):
            log_error(f"No tunnel running on port {params['port']}")
            print(f"    Start one first: surf-db-query --env {args.env} --tunnel start")
            sys.exit(1)

        # Default output path
        if not args.output:
            DEFAULT_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            args.output = str(DEFAULT_OUTPUT_DIR / f"{env}-{db_name}-{timestamp}.parquet")

    elif args.port and args.user and args.dbname:
        params = {
            "host": args.host,
            "port": args.port,
            "user": args.user,
            "password": args.password or "",
            "dbname": args.dbname,
            "db_type": args.db_type,
        }
        if not args.output:
            DEFAULT_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            args.output = str(DEFAULT_OUTPUT_DIR / f"export-{timestamp}.parquet")
    else:
        parser.error("Either --env or --host/--port/--user/--dbname is required")

    log_info(f"Exporting to {args.output}...")
    export_to_parquet(
        args.sql,
        args.output,
        params["host"],
        params["port"],
        params["user"],
        params["password"],
        params["dbname"],
        params["db_type"],
    )

    file_size = os.path.getsize(args.output)
    if file_size < 1024:
        size_str = f"{file_size} B"
    elif file_size < 1024 * 1024:
        size_str = f"{file_size / 1024:.1f} KB"
    else:
        size_str = f"{file_size / (1024 * 1024):.1f} MB"

    log_info(f"Done! {size_str}")
    print(f"    {args.output}")


if __name__ == "__main__":
    main()
