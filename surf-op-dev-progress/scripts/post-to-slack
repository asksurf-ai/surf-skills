#!/usr/bin/env bash
# Posts a Notion link to Slack via incoming webhook.
#
# Usage:
#   scripts/post-to-slack --title "Dev Team Progress — 2026-02-12" --url "https://notion.so/..."
#
# The script loads the Slack webhook URL from AWS Secrets Manager (slack/dev-progress-webhook).
#
# Requires: aws, curl, python3

set -euo pipefail

AWS_SECRET_ID="slack/dev-progress-webhook"

TITLE=""
URL=""

while [ $# -gt 0 ]; do
  case "$1" in
    --title) TITLE="$2"; shift 2 ;;
    --url) URL="$2"; shift 2 ;;
    --check-setup)
      echo "Checking setup..."
      if ! command -v aws >/dev/null 2>&1; then
        echo "FAIL: aws CLI not found"; exit 1
      fi
      WEBHOOK=$(aws secretsmanager get-secret-value --secret-id "$AWS_SECRET_ID" --query SecretString --output text 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin)['url'])" 2>/dev/null) || true
      if [ -z "$WEBHOOK" ]; then
        echo "FAIL: Could not fetch slack/dev-progress-webhook from AWS Secrets Manager"; exit 1
      fi
      echo "OK: Webhook URL loaded (${WEBHOOK:0:45}...)"
      echo "Setup OK."
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [ -z "$TITLE" ]; then
  echo "Error: --title is required" >&2; exit 1
fi

if [ -z "$URL" ]; then
  echo "Error: --url is required" >&2; exit 1
fi

# Load webhook URL from AWS Secrets Manager
WEBHOOK=$(aws secretsmanager get-secret-value --secret-id "$AWS_SECRET_ID" --query SecretString --output text | python3 -c "import sys,json; print(json.load(sys.stdin)['url'])")

if [ -z "$WEBHOOK" ]; then
  echo "Error: Could not fetch Slack webhook from AWS Secrets Manager ($AWS_SECRET_ID)" >&2
  exit 1
fi

# Post to Slack
PAYLOAD=$(python3 -c "
import json, sys
title = sys.argv[1]
url = sys.argv[2]
print(json.dumps({
    'text': f'*{title}*\n{url}'
}))
" "$TITLE" "$URL")

RESPONSE=$(curl -sS -X POST "$WEBHOOK" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD" 2>&1)

if [ "$RESPONSE" = "ok" ]; then
  echo "Posted to Slack: $TITLE"
else
  echo "Error posting to Slack: $RESPONSE" >&2
  exit 1
fi
