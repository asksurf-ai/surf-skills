#!/usr/bin/env bash
# surf-project — CLI for crypto project data via Hermod API
# Usage: surf-project <subcommand> --project NAME

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../../../lib/config.sh"
source "$SCRIPT_DIR/../../../lib/http.sh"

API_PREFIX="/v1/project"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-project",
  "subcommands": {
    "overview":         {"args": "--project NAME", "description": "Get project overview (1 credit)"},
    "token-info":       {"args": "--project NAME", "description": "Get token information (1 credit)"},
    "funding":          {"args": "--project NAME", "description": "Get funding rounds (1 credit)"},
    "team":             {"args": "--project NAME", "description": "Get team members (1 credit)"},
    "contract-address": {"args": "--project NAME", "description": "Get contract addresses (1 credit)"},
    "social":           {"args": "--project NAME", "description": "Get social links (1 credit)"},
    "volume":           {"args": "--project NAME", "description": "Get volume data (1 credit)"},
    "fee":              {"args": "--project NAME", "description": "Get fee data (1 credit)"},
    "revenue":          {"args": "--project NAME", "description": "Get revenue data (1 credit)"},
    "tvl":              {"args": "--project NAME", "description": "Get TVL data (1 credit)"},
    "users":            {"args": "--project NAME", "description": "Get user metrics (1 credit)"},
    "search":           {"args": "--query NAME [--limit 5]", "description": "Muninn project search (1 credit)"},
    "tt-metrics":       {"args": "--project-id aave --metrics revenue,tvl [--start DATE] [--end DATE]", "description": "Token Terminal metrics (2 credits)"},
    "tt-ranking":       {"args": "--metric tvl [--project-ids aave,uniswap]", "description": "Token Terminal ranking (2 credits)"},
    "--check-setup":    {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

build_query() {
  local query=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project)   query="${query:+$query&}project=$2"; shift 2 ;;
      --interval)  query="${query:+$query&}interval=$2"; shift 2 ;;
      --limit)     query="${query:+$query&}limit=$2"; shift 2 ;;
      *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; return 1 ;;
    esac
  done
  echo "$query"
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  # Semantic endpoints
  overview|token-info|funding|team|contract-address|social|volume|fee|revenue|tvl|users)
    subcmd="$1"; shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/${subcmd}" "$query"
    ;;

  # Muninn proxy — project search
  search)
    shift; q=""; limit="5"
    while [[ $# -gt 0 ]]; do case "$1" in --query) q="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$q" ]] && { echo '{"error": "--query is required"}' >&2; exit 1; }
    surf_proxy_get "muninn" "/v1/agents/search" "query=${q}&limit=${limit}"
    ;;

  # Token Terminal proxy — metrics
  tt-metrics)
    shift; pid=""; metrics=""; start_date=""; end_date=""; chains=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --project-id) pid="$2"; shift 2 ;; --metrics) metrics="$2"; shift 2 ;;
        --start) start_date="$2"; shift 2 ;; --end) end_date="$2"; shift 2 ;;
        --chains) chains="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;;
      esac
    done
    [[ -z "$pid" ]] && { echo '{"error": "--project-id is required (e.g. aave, uniswap)"}' >&2; exit 1; }
    [[ -z "$metrics" ]] && { echo '{"error": "--metrics is required (e.g. revenue,tvl,fees)"}' >&2; exit 1; }
    q="metric_ids=${metrics}"
    [[ -n "$start_date" ]] && q="${q}&start=${start_date}"
    [[ -n "$end_date" ]] && q="${q}&end=${end_date}"
    [[ -n "$chains" ]] && q="${q}&chain_ids=${chains}"
    surf_proxy_get "tt" "/v2/projects/${pid}/metrics" "$q"
    ;;

  # Token Terminal proxy — rankings
  tt-ranking)
    shift; metric=""; pids=""
    while [[ $# -gt 0 ]]; do case "$1" in --metric) metric="$2"; shift 2 ;; --project-ids) pids="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$metric" ]] && { echo '{"error": "--metric is required (e.g. tvl, revenue, fees)"}' >&2; exit 1; }
    q=""; [[ -n "$pids" ]] && q="project_ids=${pids}"
    surf_proxy_get "tt" "/v2/metrics/${metric}" "$q"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Use --help for usage.\"}" >&2; exit 1 ;;
esac
